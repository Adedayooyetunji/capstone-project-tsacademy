apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: taskapp-ingress
  annotations:
    kubernetes.io/ingress.class: alb
spec:
  rules:
  - host: taskapp.example.com
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: taskapp-service
            port:
              number: 80
