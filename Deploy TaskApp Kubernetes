apiVersion: apps/v1
kind: Deployment
metadata:
  name: taskapp
spec:
  replicas: 3
  selector:
    matchLabels:
      app: taskapp
  template:
    metadata:
      labels:
        app: taskapp
    spec:
      containers:
      - name: taskapp
        image: your-docker/taskapp:latest
        ports:
        - containerPort: 80
apiVersion: v1
kind: Service
metadata:
  name: taskapp-service
spec:
  type: ClusterIP
  selector:
    app: taskapp
  ports:
  - port: 80
    targetPort: 80
