 CI/CD TaskApp

on:
  push:
    branches:
      - main

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v3
    - name: Configure AWS Credentials
      uses: aws-actions/configure-aws-credentials@v2
      with:
        aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
        aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
        aws-region: us-east-1
    - name: Build Docker image
      run: |
        docker build -t ${{ secrets.ECR_REPO_URI }}:latest .
        aws ecr get-login-password | docker login --username AWS --password-stdin ${{ secrets.ECR_REPO_URI }}
        docker push ${{ secrets.ECR_REPO_URI }}:latest
    - name: Deploy to EKS
      run: |
        aws eks update-kubeconfig --name taskapp-cluster --region us-east-1
        helm upgrade --install taskapp ./taskapp-helm -f ./taskapp-helm/values.yaml
